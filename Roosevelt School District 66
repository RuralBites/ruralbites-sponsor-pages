<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>RuralBites | Roosevelt School District 66 | Summer 2026</title>

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700;800&display=swap" rel="stylesheet">

  <style>
    :root{
      --green:#0B7A43;
      --dark-navy:#062B3A;
      --gold:#F2D15B;
      --white:#FFFFFF;
      --light-bg:#F5F5F2;
      --body-text:#3A3A3A;
      --muted:#5E5E5E;
      --border:#DDE6E0;
      --shadow:0 12px 30px rgba(6,43,58,.08);
      --radius:22px;
      --max:1120px;
    }

    *{
      box-sizing:border-box;
      margin:0;
      padding:0;
    }

    html{
      scroll-behavior:smooth;
    }

    body{
      font-family:'Poppins',sans-serif;
      background:var(--light-bg);
      color:var(--body-text);
      line-height:1.7;
      -webkit-font-smoothing:antialiased;
    }

    img{
      max-width:100%;
      display:block;
    }

    .wrap{
      width:min(100% - 32px, var(--max));
      margin:0 auto;
    }

    .topbar{
      background:var(--white);
      border-bottom:1px solid rgba(6,43,58,.08);
      position:sticky;
      top:0;
      z-index:20;
      box-shadow:0 4px 18px rgba(6,43,58,.04);
    }

    .topbar-inner{
      width:min(100% - 32px, var(--max));
      margin:0 auto;
      min-height:86px;
      display:flex;
      align-items:center;
      justify-content:space-between;
      gap:20px;
      padding:14px 0;
    }

    .brand{
      display:flex;
      align-items:center;
      gap:16px;
      flex-wrap:wrap;
    }

    .brand img{
      height:58px;
      width:auto;
      object-fit:contain;
    }

    .brand-meta{
      display:flex;
      flex-direction:column;
      gap:2px;
    }

    .brand-meta .eyebrow{
      font-size:.74rem;
      text-transform:uppercase;
      letter-spacing:.14em;
      font-weight:700;
      color:var(--green);
    }

    .brand-meta .sub{
      font-size:.95rem;
      color:var(--dark-navy);
      font-weight:600;
    }

    .hero{
      padding:82px 0 58px;
      background:
        linear-gradient(rgba(6,43,58,.55), rgba(6,43,58,.55)),
        url('https://rtqobxqqxprhfgbvvniq.supabase.co/storage/v1/object/public/blog-images/NM%20Staff.png') center/cover no-repeat;
      color:var(--white);
      position:relative;
      overflow:hidden;
    }

    .hero::after{
      content:"";
      position:absolute;
      right:-70px;
      bottom:-70px;
      width:240px;
      height:240px;
      border-radius:50%;
      background:rgba(242,209,91,.10);
    }

    .hero-inner{
      max-width:900px;
      position:relative;
      z-index:1;
    }

    .hero-kicker{
      display:inline-block;
      font-size:.78rem;
      text-transform:uppercase;
      letter-spacing:.16em;
      font-weight:700;
      color:var(--gold);
      margin-bottom:18px;
    }

    .hero h1{
      font-size:clamp(2.1rem, 5vw, 4.1rem);
      line-height:1.06;
      font-weight:800;
      letter-spacing:-.03em;
      margin-bottom:18px;
      max-width:860px;
    }

    .hero p{
      font-size:1.05rem;
      color:rgba(255,255,255,.94);
      max-width:820px;
      font-weight:400;
      margin-bottom:14px;
    }

    .section{
      padding:68px 0;
    }

    .section.white{
      background:var(--white);
    }

    .section.light{
      background:var(--light-bg);
    }

    .label{
      display:inline-block;
      font-size:.78rem;
      text-transform:uppercase;
      letter-spacing:.14em;
      font-weight:700;
      color:var(--green);
      margin-bottom:16px;
    }

    h2{
      font-size:clamp(1.7rem, 3vw, 2.5rem);
      line-height:1.12;
      font-weight:800;
      letter-spacing:-.02em;
      color:var(--dark-navy);
      margin-bottom:14px;
      max-width:860px;
    }

    .lead{
      font-size:1.02rem;
      color:var(--muted);
      max-width:820px;
    }

    .grid-2{
      display:grid;
      grid-template-columns:repeat(2,1fr);
      gap:22px;
      margin-top:30px;
    }

    .grid-3{
      display:grid;
      grid-template-columns:repeat(3,1fr);
      gap:22px;
      margin-top:30px;
    }

    .card{
      background:var(--white);
      border:1px solid var(--border);
      border-radius:var(--radius);
      padding:28px 24px;
      box-shadow:var(--shadow);
      height:100%;
    }

    .icon{
      width:48px;
      height:48px;
      border-radius:50%;
      background:rgba(11,122,67,.10);
      color:var(--green);
      display:flex;
      align-items:center;
      justify-content:center;
      font-size:1.2rem;
      margin-bottom:14px;
      font-weight:700;
    }

    .card h3{
      font-size:1rem;
      line-height:1.3;
      font-weight:700;
      color:var(--dark-navy);
      margin-bottom:10px;
    }

    .card p{
      font-size:.97rem;
      color:var(--muted);
    }

    .spotlight{
      margin-top:28px;
      background:var(--dark-navy);
      color:var(--white);
      border-radius:26px;
      padding:34px 30px;
      box-shadow:var(--shadow);
    }

    .spotlight h3{
      font-size:1.12rem;
      font-weight:700;
      color:var(--gold);
      margin-bottom:10px;
    }

    .spotlight p{
      color:rgba(255,255,255,.92);
      max-width:860px;
    }

    .list-card{
      background:var(--white);
      border:1px solid var(--border);
      border-radius:var(--radius);
      padding:30px 24px;
      box-shadow:var(--shadow);
      margin-top:26px;
    }

    .list-card h3{
      font-size:1rem;
      font-weight:700;
      color:var(--dark-navy);
      margin-bottom:14px;
    }

    .list{
      list-style:none;
      display:grid;
      gap:12px;
    }

    .list li{
      position:relative;
      padding-left:24px;
      color:var(--muted);
      font-size:.97rem;
    }

    .list li::before{
      content:"✓";
      position:absolute;
      left:0;
      top:0;
      color:var(--green);
      font-weight:700;
    }

    .table-wrap{
      margin-top:30px;
      overflow-x:auto;
      border-radius:18px;
      border:1px solid var(--border);
      background:var(--white);
      box-shadow:var(--shadow);
    }

    .program-table{
      width:100%;
      min-width:760px;
      border-collapse:collapse;
    }

    .program-table thead th{
      background:var(--dark-navy);
      padding:18px 20px;
      font-size:.9rem;
      font-weight:700;
      letter-spacing:.06em;
      text-transform:uppercase;
      text-align:left;
      white-space:nowrap;
    }

    .program-table thead th:first-child{
      color:var(--white);
    }

    .program-table thead th:not(:first-child){
      color:var(--gold);
      text-align:center;
    }

    .program-table tbody td{
      padding:20px;
      border-bottom:1px solid var(--border);
      font-size:1rem;
      color:var(--body-text);
      background:var(--white);
    }

    .program-table tbody tr:nth-child(2){
      background:#FAFAF8;
    }

    .program-table tbody tr:nth-child(2) td{
      background:#FAFAF8;
    }

    .program-table tbody tr:last-child td{
      border-bottom:none;
    }

    .program-table tbody td:first-child{
      font-weight:600;
      color:var(--dark-navy);
      width:28%;
    }

    .program-table tbody td:not(:first-child){
      text-align:center;
      font-weight:700;
      color:#222222;
    }

    .table-note{
      margin-top:16px;
      font-size:.92rem;
      color:#6E6E6E;
      font-style:italic;
      line-height:1.7;
    }

    .table-note strong{
      color:var(--green);
      font-style:normal;
    }

    .footer{
      padding:28px 0 44px;
      background:var(--light-bg);
      border-top:1px solid rgba(6,43,58,.08);
    }

    .footer-inner{
      display:flex;
      align-items:center;
      justify-content:space-between;
      gap:20px;
      flex-wrap:wrap;
    }

    .footer small{
      color:#6E6E6E;
      font-size:.84rem;
    }

    .contact{
      display:flex;
      gap:18px;
      flex-wrap:wrap;
    }

    .contact a{
      color:var(--dark-navy);
      text-decoration:none;
      font-weight:600;
      font-size:.94rem;
    }

    .contact a:hover{
      text-decoration:underline;
    }

    .cta{
      display:inline-block;
      margin-top:12px;
      padding:14px 22px;
      border-radius:999px;
      background:var(--green);
      color:var(--white);
      text-decoration:none;
      font-weight:600;
      transition:.2s ease;
    }

    .cta:hover{
      background:#096636;
      transform:translateY(-1px);
    }

    @media (max-width: 900px){
      .grid-2,
      .grid-3{
        grid-template-columns:1fr;
      }
    }

    @media (max-width: 640px){
      .topbar-inner{
        align-items:flex-start;
        min-height:auto;
      }

      .brand{
        align-items:flex-start;
        flex-direction:column;
        gap:10px;
      }

      .brand img{
        height:52px;
      }

      .hero{
        padding:62px 0 46px;
      }

      .section{
        padding:52px 0;
      }
    }
  </style>
</head>
<body>

  <header class="topbar">
    <div class="topbar-inner">
      <div class="brand">
        <img src="https://rtqobxqqxprhfgbvvniq.supabase.co/storage/v1/object/public/blog-images/The%20infrastructure%20behind%20every%20meal%20delivered..png" alt="RuralBites logo">
        <div class="brand-meta">
          <span class="eyebrow">RuralBites</span>
          <span class="sub">Roosevelt School District 66 | Summer 2026</span>
        </div>
